NODE_ENV=development
PORT=4000
API_BASE_PATH=/api/v1
MONGODB_URI=mongodb://localhost:27017/orgflow
# Must be >= 32 chars. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-32-plus-random-character-secret-abcdef
JWT_EXPIRES_IN=7d
# Comma-separated list; no wildcard.
CORS_ORIGIN=http://localhost:5173
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIMENSIONS=768
MAX_UPLOAD_SIZE_MB=10
LOG_LEVEL=info
# Set to 1 to use in-memory cosine similarity instead of Atlas $vectorSearch (for local dev/CI).
DEV_VECTOR_FALLBACK=1
